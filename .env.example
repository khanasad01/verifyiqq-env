# OpenEnv Hackathon - Agent Configuration

# The URL of the LLM provider API endpoint (OpenAI compatible)
API_BASE_URL="https://api.openai.com/v1"

# The Model identifier used for executing inference.py
MODEL_NAME="gpt-4o"

# Your specific API Key (Hugging Face or OpenAI, depending on provider)
HF_TOKEN="your_hf_or_openai_api_key_here"

# The local environment server URL
VERIFYIQ_URL="http://localhost:8000"
